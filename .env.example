# Server Port
PORT=3000

# Database Configuration (Hostinger / MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=movie_db

# API Source
API_BASE_URL=https://phimapi.com

# Deployment allowed origin
ALLOWED_ORIGIN=*

# Frontend URL for API calls
NEXT_PUBLIC_API_URL=http://localhost:3000

# Session Secret (min 32 characters)
SESSION_SECRET=changethissecret12345678901234567890

# SMTP — gửi mã xác nhận OTP qua email khi đăng ký
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
